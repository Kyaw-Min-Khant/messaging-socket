# Server
PORT=4004
NODE_ENV=development

# Must be byte-identical to the JWT_SECRET used by auth-service / gateway / every other service
JWT_SECRET=

# Local dev (docker-compose expense-db) — production uses Render-managed Postgres instead
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/expenses?schema=public

# Comma-separated browser origins allowed for CORS (only exercised in local/dev before the gateway centralizes CORS)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000
