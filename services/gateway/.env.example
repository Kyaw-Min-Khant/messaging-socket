# Server
PORT=4000
NODE_ENV=development

# Comma-separated browser origins allowed for CORS (centralized here — the only public service)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

# Internal routing targets — in docker-compose these resolve via service-name DNS,
# on Render these are Private Service URLs, never exposed publicly.
EXPENSE_SERVICE_URL=http://localhost:4004
MONOLITH_URL=http://localhost:1500
