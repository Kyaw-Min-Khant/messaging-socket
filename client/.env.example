# Main API (monolith or gateway)
# VITE_API_URL=https://messaging-socket.onrender.com/v1/api

# Expense microservice — separate URL since it runs on its own Render service
# VITE_EXPENSE_API_URL=https://expense-service-8i5i.onrender.com/v1/api
