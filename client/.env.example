# Optional: override the proxy target (defaults to http://localhost:1500)
# VITE_API_PROXY_TARGET=http://localhost:1500

# Optional: override where /v1/api/expenses is proxied to (defaults to http://localhost:4004)
# VITE_EXPENSE_API_PROXY_TARGET=http://localhost:4004

