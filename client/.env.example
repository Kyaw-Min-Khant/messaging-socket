# Firebase Web App config (from Firebase Console → Project Settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=

# Local dev: leave unset to use Vite proxy (/v1/api → backend on port 1500)
# VITE_API_PROXY_TARGET=http://localhost:1500

# Production web build: point at deployed API
# VITE_API_URL=https://messaging-socket.onrender.com/v1/api
