# Server
PORT=1500
APP_NAME=Messaging App
NODE_ENV=development

# Comma-separated browser origins allowed for CORS + Socket.IO (your web app URLs)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

# Production database (Atlas) — used when NODE_ENV is not "development"
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/messaging

# Production Redis (Redis Cloud) — used when NODE_ENV is not "development"
REDIS_URL=
REDIS_PASSWORD=
REDIS_PORT=

# Local dev overrides (NODE_ENV=development)
DEV_MONGODB_URI=mongodb://127.0.0.1:27017/messaging
DEV_REDIS_URL=127.0.0.1
DEV_REDIS_PORT=6379
DEV_REDIS_PASSWORD=

JWT_SECRET=
JWT_EXPIRES_IN=15d

# Firebase Admin (server)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# --- Render production checklist ---
# NODE_ENV=production
# MONGODB_URI=<Atlas URI>
# REDIS_URL / REDIS_PASSWORD / REDIS_PORT=<Redis Cloud>
# CLIENT_URL=https://your-web-app.onrender.com
